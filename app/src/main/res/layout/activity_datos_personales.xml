<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".DatosPersonalesActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!--Imagen superior-->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:src="@drawable/logo"
                android:contentDescription="Logo Escuela" />

            <!--Mensaje informativo-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Los campos marcados como (obligatorio) deben rellenarse para registrar al alumno."
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- DATOS PERSONALES-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DATOS PERSONALES"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="10dp" />

            <!--Nombre y apellidos-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOMBRE Y APELLIDOS (obligatorio):"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etNombreApellidos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Introduce nombre y apellidos"
                    android:textColorHint="#808080"
                    android:inputType="textPersonName" />
            </LinearLayout>

            <!--Fecha de nacimiento-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FECHA DE NACIMIENTO (obligatorio):"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etFechaNacimiento"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="dd/mm/aaaa"
                    android:textColorHint="#808080"
                    android:inputType="date" />
            </LinearLayout>

            <!--DNI-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DNI / NIF (obligatorio):"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etDNI"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="8 dígitos + letra"
                    android:textColorHint="#808080"
                    android:maxLength="9"
                    android:inputType="number"/>
            </LinearLayout>

            <!--Dirección-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIRECCIÓN (obligatorio):"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etDireccion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Calle y número"
                    android:textColorHint="#808080"
                    android:inputType="textPostalAddress" />
            </LinearLayout>

            <!--Teléfono-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TELÉFONO:"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etTelefono"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Teléfono del alumno"
                    android:textColorHint="#808080"
                    android:inputType="phone" />
            </LinearLayout>

            <!--ESPACIO-->
            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!--Botones-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <Button
                    android:id="@+id/btnBorrar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BORRAR"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#D32F2F"
                    android:layout_margin="8dp" />

                <Button
                    android:id="@+id/btnGuardar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GUARDAR"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#071C47"
                    android:layout_margin="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>