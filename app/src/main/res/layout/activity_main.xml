<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Imagen superior (editable) -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Logo Escuela" />

            <!-- ========== DATOS PERSONALES ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DATOS PERSONALES"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="10dp" />

            <!-- Nombre y apellidos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOMBRE Y APELLIDOS:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etNombreApellidos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Introduce nombre y apellidos"
                    android:inputType="textPersonName" />
            </LinearLayout>

            <!-- Fecha de nacimiento -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FECHA DE NACIMIENTO:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etFechaNacimiento"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="dd/mm/aaaa"
                    android:inputType="date" />
            </LinearLayout>

            <!-- DNI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DNI / NIF:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etDNI"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="8 dígitos + letra"
                    android:maxLength="9"
                    android:inputType="text" />
            </LinearLayout>

            <!-- Dirección -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIRECCIÓN:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etDireccion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Calle y número"
                    android:inputType="textPostalAddress" />
            </LinearLayout>

            <!-- Teléfono -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TELÉFONO (opcional):"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etTelefono"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Teléfono del alumno"
                    android:inputType="phone" />
            </LinearLayout>

            <!-- ESPACIO -->
            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- ========== DATOS DEL TUTOR ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DATOS DEL TUTOR"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="10dp" />

            <!-- Nombre tutor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOMBRE Y APELLIDOS:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etNombreTutor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Nombre completo del tutor"
                    android:inputType="textPersonName" />
            </LinearLayout>

            <!-- DNI tutor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DNI / NIF:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etDNITutor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="8 dígitos + letra"
                    android:maxLength="9"
                    android:inputType="text" />
            </LinearLayout>

            <!-- Teléfono tutor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TELÉFONO:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etTelefonoTutor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Teléfono obligatorio si menor"
                    android:inputType="phone" />
            </LinearLayout>

            <!-- Email tutor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CORREO ELECTRÓNICO:"
                    android:textColor="#000"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/etEmailTutor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="ejemplo@email.com"
                    android:inputType="textEmailAddress" />
            </LinearLayout>

            <!-- ESPACIO -->
            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- ========== DATOS MÉDICOS ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DATOS MÉDICOS"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etAlergias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Alergias"
                android:inputType="textMultiLine" />

            <EditText
                android:id="@+id/etCondicionMedica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Condición médica"
                android:inputType="textMultiLine"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etMedicamentos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Medicamentos"
                android:inputType="textMultiLine"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etTelefonoEmergencias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Teléfono de emergencias"
                android:inputType="phone"
                android:layout_marginTop="8dp" />

            <!-- ESPACIO -->
            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- ========== INFORMACIÓN SOBRE EL DEPORTE ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="INFORMACIÓN SOBRE EL DEPORTE"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/spTipoBicicleta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:prompt="@string/prompt_tipo_bicicleta" />

            <Spinner
                android:id="@+id/spTalla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:prompt="@string/prompt_talla" />

            <Spinner
                android:id="@+id/spModalidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:prompt="@string/prompt_modalidad" />


            <!-- ESPACIO -->
            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- ========== PERMISOS ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PERMISOS"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="10dp" />

            <CheckBox
                android:id="@+id/cbProteccionDatos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Conozco la ley de protección de datos" />

            <CheckBox
                android:id="@+id/cbFotosRedes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Autorizo salir en fotos y redes sociales" />

            <CheckBox
                android:id="@+id/cbAsistenciaMedica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Autorizo asistencia médica en caso de emergencia" />

            <CheckBox
                android:id="@+id/cbNormasEscuela"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Conozco las normas de la escuela" />

            <!-- ESPACIO FINAL -->
            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Botones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:gravity="center">

                <Button
                    android:id="@+id/btnGuardar"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Guardar" />

                <Button
                    android:id="@+id/btnBorrar"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Borrar" />

                <Button
                    android:id="@+id/btnVerLista"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Ver Alumnos" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
