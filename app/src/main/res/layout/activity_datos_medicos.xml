<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BDB8B8"
    tools:context=".DatosMedicosActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!--Imagen superior-->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:src="@drawable/logo"
        android:contentDescription="Logo Escuela" />
    <!--DATOS MÉDICOS-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DATOS MÉDICOS"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/etAlergias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Alergias"
        android:textColorHint="#808080"
        android:inputType="textMultiLine" />

    <EditText
        android:id="@+id/etCondicionMedica"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Condición médica"
        android:textColorHint="#808080"
        android:inputType="textMultiLine"
        android:layout_marginTop="8dp" />

    <EditText
        android:id="@+id/etMedicamentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Medicamentos"
        android:textColorHint="#808080"
        android:inputType="textMultiLine"
        android:layout_marginTop="8dp" />

    <EditText
        android:id="@+id/etTelefonoEmergencias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Teléfono de contacto"
        android:textColorHint="#808080"
        android:inputType="phone"
        android:layout_marginTop="8dp" />

    <!-- ESPACIO -->
    <View android:layout_width="match_parent" android:layout_height="24dp" />

        <!--Botones-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnBorrar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BORRAR"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GUARDAR"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#071C47"
                android:layout_margin="8dp" />
        </LinearLayout>

    </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>